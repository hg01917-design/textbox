# Optional: Naver Search API for blog result counts
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# Optional: Naver SearchAd API for exact monthly search volume
NAVER_API_KEY=
NAVER_SECRET_KEY=
NAVER_CUSTOMER_ID=

# Optional: OpenAI-compatible API for AI draft generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional: local CLI model generation
# Default command is `claude --print`. Override only if needed.
DRAFTER_CLI_COMMAND=claude
DRAFTER_CLI_ARGS=--print
# Default: Claude CLI uses logged-in Claude Code subscription, not ANTHROPIC_API_KEY.
# Set to 1 only if you intentionally want API-key billing for CLI generation.
DRAFTER_CLI_USE_API_KEY=0

# Optional: WordPress REST API draft save
WP_SITE_URL=
WP_USER=
WP_APP_PASSWORD=
WP_DEFAULT_STATUS=draft

# Blog Helper image/card behavior
# Card images are generated locally with Pillow. No Gemini/Bing web image automation is used by default.

# Optional: multi-account Naver/Tistory/WordPress blog IDs (managed via the app's "계정 관리" window)
NAVER_BLOG_IDS=
TISTORY_BLOG_IDS=
WP_BLOG_IDS=
# Each blog ID gets its own {PLATFORM}_{ID}_PORT (Naver/Tistory, auto-assigned) or
# {ID}_WP_URL / {ID}_WP_USER / {ID}_WP_APP_PASSWORD (WordPress) — added automatically
# when you add an account through the app, no need to set these by hand.
CHROME_PORT=9222

# Naver/Tistory login switching through one Chrome CDP profile.
# The app selects accounts already saved in Chrome; it does not type passwords unless fallback is enabled.
CHROME_USER_DATA_DIR=
LOGIN_SELECT_SAVED_ACCOUNT=1
LOGIN_PASSWORD_FALLBACK=0
LOGIN_LOGOUT_AFTER_POST=1
# Optional only when LOGIN_PASSWORD_FALLBACK=1:
# NAVER_DAONNA525_PW=
# NAVER_ME1091_PW=
# KAKAO_BAREMI542_PW=
# KAKAO_ISAG27511_PW=

# Optional: Google AdSense revenue (home dashboard) — OAuth via the app's "애드센스 연동" button.
# Needs a Google Cloud OAuth client with the AdSense Management API enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADSENSE_REFRESH_TOKEN=
